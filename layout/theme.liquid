    <head>
        <!-- Delay Third-Party App Scripts until User Interaction (Zero Layout Impact) -->
        <script>
        (function() {
          const targetKeywords = ['klaviyo', 'triplewhale', 'triple-pixel', 'bss-labels', 'king-linked-options'];
          const delayedScripts = [];
          let userInteracted = false;

          const originalCreateElement = document.createElement;
          document.createElement = function(tagName, options) {
            const element = originalCreateElement.call(document, tagName, options);
            if (tagName.toLowerCase() === 'script') {
              const originalSetAttribute = element.setAttribute;
              element.setAttribute = function(name, value) {
                if (name === 'src') {
                  const matched = targetKeywords.some(keyword => value.includes(keyword));
                  if (matched && !userInteracted) {
                    element.setAttribute('data-lazy-src', value);
                    delayedScripts.push({ element: element, src: value });
                    return;
                  }
                }
                originalSetAttribute.call(element, name, value);
              };
              Object.defineProperty(element, 'src', {
                set: function(value) {
                  const matched = targetKeywords.some(keyword => value.includes(keyword));
                  if (matched && !userInteracted) {
                    element.setAttribute('data-lazy-src', value);
                    delayedScripts.push({ element: element, src: value });
                    return;
                  }
                  element.setAttribute('src', value);
                },
                get: function() {
                  return element.getAttribute('src') || element.getAttribute('data-lazy-src') || '';
                }
              });
            }
            return element;
          };

          const originalAppendChild = Node.prototype.appendChild;
          Node.prototype.appendChild = function(child) {
            if (child && child.tagName === 'SCRIPT') {
              const src = child.src || child.getAttribute('src') || child.getAttribute('data-lazy-src') || '';
              const matched = targetKeywords.some(keyword => src.includes(keyword));
              if (matched && !userInteracted) {
                if (!child.getAttribute('data-lazy-src')) {
                  child.setAttribute('data-lazy-src', src);
                  child.removeAttribute('src');
                }
                delayedScripts.push({ element: child, parent: this, method: 'appendChild' });
                return child;
              }
            }
            return originalAppendChild.call(this, child);
          };

          const originalInsertBefore = Node.prototype.insertBefore;
          Node.prototype.insertBefore = function(newChild, refChild) {
            if (newChild && newChild.tagName === 'SCRIPT') {
              const src = newChild.src || newChild.getAttribute('src') || newChild.getAttribute('data-lazy-src') || '';
              const matched = targetKeywords.some(keyword => src.includes(keyword));
              if (matched && !userInteracted) {
                if (!newChild.getAttribute('data-lazy-src')) {
                  newChild.setAttribute('data-lazy-src', src);
                  newChild.removeAttribute('src');
                }
                delayedScripts.push({ element: newChild, parent: this, refChild: refChild, method: 'insertBefore' });
                return newChild;
              }
            }
            return originalInsertBefore.call(this, newChild, refChild);
          };

          function loadDelayedScripts() {
            if (userInteracted) return;
            userInteracted = true;

            window.removeEventListener('scroll', loadDelayedScripts);
            window.removeEventListener('mousemove', loadDelayedScripts);
            window.removeEventListener('touchstart', loadDelayedScripts);
            window.removeEventListener('click', loadDelayedScripts);
            window.removeEventListener('keydown', loadDelayedScripts);

            delayedScripts.forEach(function(item) {
              const script = item.element;
              const src = script.getAttribute('data-lazy-src');
              if (src) {
                script.setAttribute('src', src);
                script.removeAttribute('data-lazy-src');
                if (item.parent) {
                  if (item.method === 'appendChild') {
                    originalAppendChild.call(item.parent, script);
                  } else if (item.method === 'insertBefore') {
                    originalInsertBefore.call(item.parent, script, item.refChild);
                  }
                } else {
                  originalAppendChild.call(document.head, script);
                }
              }
            });
          }

          window.addEventListener('scroll', loadDelayedScripts, { passive: true });
          window.addEventListener('mousemove', loadDelayedScripts, { passive: true });
          window.addEventListener('touchstart', loadDelayedScripts, { passive: true });
          window.addEventListener('click', loadDelayedScripts, { passive: true });
          window.addEventListener('keydown', loadDelayedScripts, { passive: true });

          setTimeout(loadDelayedScripts, 8000);
        })();
        </script>

        <!-- Tracking Scripts (Deferred for Performance) -->
        <script>
        (function() {
          var scriptsLoaded = false;
          function loadTrackingScripts() {
            if (scriptsLoaded) return;
            scriptsLoaded = true;

            // Remove event listeners
            window.removeEventListener('scroll', loadTrackingScripts);
            window.removeEventListener('mousemove', loadTrackingScripts);
            window.removeEventListener('touchstart', loadTrackingScripts);
            window.removeEventListener('keydown', loadTrackingScripts);

            // 1. Google Tag Manager
