<div class="custom-promo-section section-{{ section.id }}">
  <div class="custom-promo-grid">
    {% for block in section.blocks %}
      <div class="promo-block" {{ block.shopify_attributes }}>
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="promo-link">
        {% endif %}

        <div class="promo-image-wrapper">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'promo-image' }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'promo-placeholder' }}
          {% endif %}

          <div class="promo-overlay">
            <h3 class="promo-heading">{{ block.settings.heading }}</h3>
          </div>
        </div>

        {% if block.settings.link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 60px;
    padding-right: 60px;
    background-color: {{ section.settings.bg_color }};
  }
  
  .custom-promo-grid {
    display: grid;
    grid-template-columns: 1fr; /* Mobile and Tablet stacked layout */
    gap: 15px;
    {% comment %} max-width: {{ section.settings.max_width }}px; {% endcomment %}
    margin: 0 auto;
  }
  
  .promo-block {
    position: relative;
    width: 100%;
  }
  
  .promo-link {
    text-decoration: none;
    display: block;
    width: 100%;
  }

  .promo-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5; /* Mimics the vertical rectangle vibe in your screenshots */
    overflow: hidden;
  }
  
  .promo-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  /* Slight zoom effect on hover if there is a link */
  .promo-link:hover .promo-image {
    transform: scale(1.05);
  }
  
  .promo-placeholder {
    background-color: #e0e0e0;
    width: 100%;
    height: 100%;
  }

  .promo-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    {% comment %} background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});  {% endcomment %}
    padding: 20px;
  }

  .promo-heading {
    color: #FFFFFF;
    font-size: 24px;
    font-weight: 700;
    text-transform: uppercase;
    text-align: center;
    margin: 0;
    letter-spacing: 1px;
    text-shadow: 0px 2px 4px rgba(0,0,0,0.2); /* Helps white text pop on light backgrounds */
  }

  /* Desktop Layout */
  @media (min-width: 1024px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
    
    .custom-promo-grid {
      grid-template-columns: repeat(3, 1fr); /* 3 equal columns */
      gap: 65px;
    }
    
    .promo-heading {
      font-size: 28px;
    }
  }

    @media (max-width: 800px) {.section-{{ section.id }} {
     padding-left: 25px;
    padding-right: 25px;
    } }
</style>

{% schema %}
{
  "name": "Custom Promo Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "default": 1200
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image Darken Overlay (%)",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 10,
      "info": "Helps make text readable if images are bright."
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "promo_item",
      "name": "Promo Grid Item",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Overlay Text",
          "default": "PROMO TEXT"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Promo Grid",
      "blocks": [
        { "type": "promo_item", "settings": { "heading": "FOR PLANET" } },
        { "type": "promo_item", "settings": { "heading": "FOR PEOPLE" } },
        { "type": "promo_item", "settings": { "heading": "FOR MCM" } }
      ]
    }
  ]
}
{% endschema %}