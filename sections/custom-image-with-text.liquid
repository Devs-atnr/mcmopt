<div class="custom-media-text section-{{ section.id }}">
  <div class="media-text-container">
    
    <div class="media-text-image-wrapper">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', class: 'media-text-image' }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'media-text-placeholder' }}
      {% endif %}
    </div>

    <div class="media-text-content-wrapper">
      <div class="media-text-content-inner">
        {% if section.settings.heading != blank %}
          <h2 class="media-text-heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="media-text-body">
            {{ section.settings.text }}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="media-text-button">
            {{ section.settings.button_label }}
            <span class="button-arrow">→</span>
          </a>
        {% endif %}
      </div>
    </div>

  </div>
</div>

<style>
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .media-text-heading {
        font-size: 36px;
    font-family: 'MCM Favorit Bold Extended';
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 20px;
    text-align: start;
    line-height: 48px;
    }

  .media-text-container {
    display: grid;
    grid-template-columns: 1fr; /* Mobile stacked layout */
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
    gap: 30px;
  }

  .media-text-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1; /* Keeps image square/balanced */
    overflow: hidden;
  }

  .media-text-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-text-placeholder {
    width: 100%;
    height: 100%;
    background-color: #f3f3f3;
  }

  .media-text-content-wrapper {
    display: flex;
    align-items: center; /* Vertically center text alongside the image */
    justify-content: flex-start;
  }

  .media-text-content-inner {
    max-width: 620px; /* Prevents text from stretching too wide */
  }

  .media-text-heading {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    color: #000000;
    margin: 0 0 20px 0;
    letter-spacing: 0.5px;
  }

  .media-text-body {

    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 30px;
    font-family: 'MCM Favorit Variable';
    color: #000;

  }

  .media-text-body p {
    margin: 0;
  }

  .media-text-button {
    font-family: 'MCM Favorit Variable';
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    background-color: #000000;
    color: #FFFFFF;
    text-decoration: none;
    padding: 12px 20px;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
    min-width: 200px;
    transition: background-color 0.3s ease;
  }

  .media-text-button:hover {
    color: #FFFFFF !important;
     background-color: #000000;
  }

  .button-arrow {
    margin-left: 15px;
    font-size: 16px;
    transition: transform 0.2s ease;
  }

  .media-text-button:hover .button-arrow {
    transform: translateX(4px);
  }

  /* Desktop Layout */
  @media (min-width: 1024px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }

    .media-text-container {
      grid-template-columns: 1fr 1fr; /* Two equal columns */
      gap: 60px; /* Generous gap between image and text */
      align-items: start;
    }

    .media-text-heading {
        font-size: 36px;
    font-family: 'MCM Favorit Bold Extended';
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 20px;
    text-align: start;
    line-height: 48px;
    }

    .media-text-image-wrapper {
      /* On desktop we can keep it square or let it match content height */
      aspect-ratio: auto;
      height: 100%;
      {% comment %} max-height: 600px; {% endcomment %}
    }
  }
</style>

{% schema %}
{
  "name": "Custom Image with Text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LEARN MORE ABOUT MCM'S SUSTAINABILITY JOURNEY"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Crafting a more sustainable future is our highest priority at MCM. Using innovation, smart design and future thinking we are proud to have set ourselves an ambitious path to meet the climate goals our planet needs.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "DISCOVER MORE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section Max Width (px)",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "default": 1200
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Custom Image with Text"
    }
  ]
}
{% endschema %}