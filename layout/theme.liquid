        <script>
          (function() {
            var klaviyoEnabled = false;
            function enableKlaviyoForms() {
              if (klaviyoEnabled) return;
              klaviyoEnabled = true;
              document.body.classList.add('show-klaviyo-forms');
              window.removeEventListener('scroll', enableKlaviyoForms);
              window.removeEventListener('touchstart', enableKlaviyoForms);
              window.removeEventListener('click', enableKlaviyoForms);
            }
            // Defer popup display until first real user interaction or 9s timeout
            window.addEventListener('scroll', enableKlaviyoForms, { passive: true });
            window.addEventListener('touchstart', enableKlaviyoForms, { passive: true });
            window.addEventListener('click', enableKlaviyoForms, { passive: true });
            setTimeout(enableKlaviyoForms, 9000);
          })();
        </script>

