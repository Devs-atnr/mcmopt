{%- comment -%}
  hreflang tags for bilingual EN/AR storefront
{%- endcomment -%}
{%- if localization.available_languages.size > 1 -%}
  {%- for language in localization.available_languages -%}
    {%- assign locale_root = language.root_url -%}
    {%- if request.page_type == 'index' -%}
      {%- assign locale_href = locale_root -%}
    {%- else -%}
      {%- assign locale_href = locale_root | append: request.path -%}
    {%- endif -%}
    <link rel="alternate" hreflang="{{ language.iso_code }}" href="{{ locale_href }}">
  {%- endfor -%}
  {%- assign default_lang = localization.available_languages | first -%}
  <link rel="alternate" hreflang="x-default" href="{{ default_lang.root_url }}">
{%- endif -%}
