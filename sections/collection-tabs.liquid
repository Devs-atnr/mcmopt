
<div class="tabs">
  {% for block in section.blocks %}
    <button class="tab-links{% if forloop.first %} active{% endif %}" onclick="openTab(event, 'tab-content-{{ forloop.index0 }}')">{{ block.settings.tab_title }}</button>
  {% endfor %}
</div>

{% for block in section.blocks %}
  <div id="tab-content-{{ forloop.index0 }}" class="tab-content{% if forloop.first %} active{% endif %}" style="{% unless forloop.first %}display:none;{% endunless %}">
    {% assign collection_count = 0 %}
    {% for i in (1..10) %}
      {% assign coll_key = 'collection_' | append: i %}
      {% assign enabled_key = 'enable_collection_' | append: i %}
      {% if block.settings[coll_key] and block.settings[enabled_key] %}
        {% assign collection_count = collection_count | plus: 1 %}
        {% assign image_key = 'tab_image_' | append: i %}
        {% assign title_key = 'collection_title_' | append: i %}
        {% assign desc_key = 'collection_description_' | append: i %}
        <div class="collection-item">
          {% if block.settings[image_key] %}
            <img src="{{ block.settings[image_key] | img_url: '300x' }}" alt="{{ block.settings[title_key] }}">
          {% endif %}
          <h3>{{ block.settings[title_key] | default: 'No Title' }}</h3>
          <p>{{ block.settings[desc_key] | default: 'No Description' }}</p>
          <a href="{{ collections[block.settings[coll_key]].url }}"></a>
        </div>
      {% endif %}
    {% endfor %}
    {% if collection_count == 0 %}
      <p>No collections to display.</p>
    {% endif %}
  </div>
{% endfor %}

<script>
function openTab(evt, tabName) {
  var i, tabcontent, tablinks;
  tabcontent = document.getElementsByClassName("tab-content");
  for (i = 0; i < tabcontent.length; i++) {
    tabcontent[i].style.display = "none";
  }
  tablinks = document.getElementsByClassName("tab-links");
  for (i = 0; i < tablinks.length; i++) {
    tablinks[i].className = tablinks[i].className.replace(" active", "");
  }
  document.getElementById(tabName).style.display = "block";
  evt.currentTarget.className += " active";
}
</script>

<style>
 .collection-item  p {
color: gray;
    font-size: 14px;
    margin: 0;
}
 .collection-item h3 {
    order: 1;
       font-size: 14px;
}
  .collection-item {
    display: flex;

    flex-direction: column-reverse;
    flex: 0 0 auto;
    flex-wrap: wrap;
    justify-content: center;
}
  div#tab-content-0 {
    display: flex;
    gap: 3%;
    flex-wrap: wrap;
}


.tabs button.tab-links {
  background-color: #f1f1f1;
  border: none;
  outline: none;
  cursor: pointer;
  padding: 10px 20px;
  transition: 0.3s;
}
.tabs button.tab-links.active {
  background-color: #ccc;
}
.tab-content {
  display: none;
  padding: 20px;
  border: 1px solid #ccc;
  border-top: none;
}
.tab-content.active {
  display: block;
}

</style>
