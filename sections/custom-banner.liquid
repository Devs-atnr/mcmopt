
{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {"type": "text",
   "id": "custom_class",
   "label": "Custom CSS Class (optional)" },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "url",
      "id": "desktop_video_mp4",
      "label": "Desktop MP4 Video URL",
      "info": "Upload an MP4 file to your Shopify Files and paste the link here."
    },
    {
      "type": "url",
      "id": "mobile_video_mp4",
      "label": "Mobile MP4 Video URL",
      "info": "Upload an MP4 file to your Shopify Files and paste the link here."
    },
    {
      "type": "image_picker",
      "id": "video_cover_image",
      "label": "Video Cover Image"
    },
    {
      "type": "textarea",
      "id": "text_content",
      "label": "Content Text"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "label": "Text Font Size (px)",
      "min": 10,
      "max": 100,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "link_font_size",
      "label": "Link Text Font Size (px)",
      "min": 10,
      "max": 100,
      "step": 1,
      "default": 16
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },

    /* Button 1 */
    {
      "type": "text",
      "id": "link_text_1",
      "label": "Button 1 Text",
      "default": "Click Here"
    },
    {
      "type": "url",
      "id": "link_url_1",
      "label": "Button 1 URL"
    },

    /* Button 2 */
    {
      "type": "text",
      "id": "link_text_2",
      "label": "Button 2 Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "link_url_2",
      "label": "Button 2 URL"
    },

    /* Button 3 */
    {
      "type": "text",
      "id": "link_text_3",
      "label": "Button 3 Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "link_url_3",
      "label": "Button 3 URL"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner",
      "category": "Custom"
    }
  ]
}
{% endschema %}


{%- if section.settings.desktop_image -%}
  <link rel="preload" as="image" href="{{ section.settings.desktop_image | img_url: '1920x', format: 'webp' }}" media="(min-width: 769px)" fetchpriority="high">
{%- endif -%}
{%- if section.settings.mobile_image -%}
  <link rel="preload" as="image" href="{{ section.settings.mobile_image | img_url: '750x', format: 'webp' }}" media="(max-width: 768px)" fetchpriority="high">
{%- endif -%}

<style>
  
  {% comment %} .ban-end { height: 100vh !important; background-size: contain !important; background-repeat: no-repeat !important; } {% endcomment %}
    @media (max-width: 551px) {   
    .ban-end { max-height: 45vh !important; }
    .ban-two { max-height: 55vh !important; }
    
    
    
     } {% comment %} query end {% endcomment %}

     @media (min-width: 552px) and (max-width: 768px) {   
    .ban-two { max-height: 100vh !important; }
    .ban-end { max-height: 80vh !important; }
    
    
    
    } {% comment %} query end {% endcomment %}

  .shopify-section-banner {
    height: 120vh;
    padding: 0;
    margin: 0;
    background-size: cover;
    background-position: center;
  }

  .content-box {
    width: 100%;
    margin: 0 auto;
    padding: 20px;
    position: absolute;
    bottom: 0;
    color: {{ section.settings.text_color }};
    z-index: 2; /* Ensure the content is above the video */
  }

  .banner_link_full {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
  }
  @media (max-width: 551px) {
    h1, .banner_link {
      font-size: 14px;
    }
    div.new-clas {
    max-height: 55vh !important;
}
  }

  /* Video Container */
  .video-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 1; /* Ensure the video is behind the content */
  }

  .video-container video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .desktop-video {
    display: block;
    height: -webkit-fill-available;
  }

  .mobile-video {
    display: none;
  }

  @media (max-width: 1025px) {
.video-container {
    height: 100vh !important;
}
    .desktop-video {
      display: none;
    }

    .mobile-video {
      display: block;
          height: -webkit-fill-available;
              /* height: 100vh; */
    }
.video-container video {
    height: auto !important;
  }
  }
  /* tablets show only 2  */
@media (min-width: 767px) and (max-width: 1025px) {
.video-container {
    height: 120vh !important;
}
  .container-box{
    height: 100vh;
  }
    .desktop-video {
      display: none;
    }

    .mobile-video {
      display: block;
      height: -webkit-fill-available;
           
    }
.video-container video {
    height: -webkit-fill-available !important;
  }
}

  
  span.link_text:hover {
    color: {{ section.settings.text_color }};
    margin-left: 8px;
  }

  span.link_text {
    transition: margin-left 0.3s ease;
  }

  body, html {
    height: 100%;
    scroll-behavior: smooth;
  }


  .container-box {
    position: relative;
    height: 100%;
  }

  h1 {
    font-size: {{ section.settings.text_font_size }}px;
    color: {{ section.settings.text_color }} !important;
    font-family: 'MCMFavorit-Regularbh';
    font-weight: unset !important;
    text-transform: uppercase;
        letter-spacing: normal;
        line-height: 1.2;

  }

  .banner_link {
    font-size: {{ section.settings.link_font_size }}px;
    color: {{ section.settings.text_color }};
    text-decoration: none;
    font-family: 'MCMFavorit-Regularbh', sans-serif;
    font-weight: unset !important;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
    letter-spacing: normal;
        line-height: 1.2;
  }

@media (max-width: 551px){
  h1, .banner_link{
    font-size: 14px;
  }
}

  {% if section.settings.desktop_image %}
    /* Dynamic background images using section.id */
    #shopify-section-{{ section.id }}.shopify-section-banner {
      background-image: url('{{ section.settings.desktop_image | img_url: '1920x', format: 'webp' }}');
    }
  {% endif %}

  {% if section.settings.mobile_image %}
    /* Tablet background image */
    @media (min-width: 552px) and (max-width: 768px) {
      #shopify-section-{{ section.id }}.shopify-section-banner {
        background-image: url('{{ section.settings.mobile_image | img_url: '1000x', format: 'webp' }}');
        max-height: 130vh;
      }
      .content-box {
        padding-bottom: 60px !important;
      }
    }

    /* Mobile background image */
    @media (max-width: 551px) {
      #shopify-section-{{ section.id }}.shopify-section-banner {
        background-image: url('{{ section.settings.mobile_image | img_url: '750x', format: 'webp' }}');
        max-height: 75vh;
      }
      .video-container video {
        height: 100vh !important;
      }
      .shopify-section-banner {
        height: 100vh;
      }
    }
  {% endif %}
    
  span.link_text:hover {
    color: {{ section.settings.text_color }};
  }
  span.link_text {
    margin-inline-end: 20px;
  }
</style>

<div id="shopify-section-{{ section.id }}" class="shopify-section-banner {{ section.settings.custom_class }}">
  <div class="container-box">
    <!-- Video Container -->
    {% if section.settings.desktop_video_mp4 or section.settings.mobile_video_mp4 %}
      <div class="video-container">
        {% if section.settings.desktop_video_mp4 %}
          <div class="desktop-video">
            <video
              autoplay
              muted
              loop
              playsinline
              {% if section.settings.video_cover_image %}poster="{{ section.settings.video_cover_image | img_url: 'master' }}"{% endif %}
            >
              <source src="{{ section.settings.desktop_video_mp4 }}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
          </div>
        {% endif %}
        {% if section.settings.mobile_video_mp4 %}
          <div class="mobile-video">
            <video
              autoplay
              muted
              loop
              playsinline
              {% if section.settings.video_cover_image %}poster="{{ section.settings.video_cover_image | img_url: 'master' }}"{% endif %}
            >
              <source src="{{ section.settings.mobile_video_mp4 }}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <!-- Content Box -->
    {% comment %} <a class="banner_link_full" href="{{ section.settings.link_url }}"></a> {% endcomment %}
<div class="content-box">
  <h1 style="color: {{ section.settings.text_color }}; font-size: {{ section.settings.text_font_size }}px;">
    {{ section.settings.text_content }}
  </h1>

  <div class="banner-links">
    {% for i in (1..3) %}
      {% assign link_text_key = 'link_text_' | append: i %}
      {% assign link_url_key  = 'link_url_'  | append: i %}
      {% assign link_text_val = section.settings[link_text_key] %}
      {% assign link_url_val  = section.settings[link_url_key] %}
      {% if link_text_val != blank and link_url_val != blank %}
        <a class="banner_link" href="{% if request.locale.iso_code == 'ar' %}/ar{{ link_url_val }}{% else %}{{ link_url_val }}{% endif %}">

          <span class="link_text" style="font-size: {{ section.settings.link_font_size }}px;">
            <svg width="20" height="20" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M12.129 8.24999L8.106 4.22699L9.1665 3.16649L15 8.99999L9.1665 14.8335L8.106 13.773L12.129 9.74999H3V8.24999H12.129Z" fill="#{{ section.settings.arrow_color | remove: '#' }}"/>
            </svg>
            {{ link_text_val }}
          </span>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>
     {% comment %} <a class="banner_link_full" href="{{ section.settings.link_url }}"></a>    {% endcomment %}
  </div>
</div>

{% if request.locale.iso_code == 'ar' %}
<style>
div.bh-banner-sale {
    background-image: url(https://cdn.shopify.com/s/files/1/0888/3594/8829/files/HP-Banners-Desktop-figma-size-Arb_jpg.jpg?v=1780582244) !important;
