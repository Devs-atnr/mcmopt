            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-KZRNVZTC');

            // 2. GA4 Server-Side GTM
            var SGTM_HOST = 'https://rails.mcmworldwide.sa'.replace(/\/$/, '');
            var GA4_ID = 'G-TMZ8Q54R1B';
            window.dataLayer = window.dataLayer || [];
            if (typeof gtag !== 'function') {
              window.gtag = function(){ dataLayer.push(arguments); };
            }
            gtag('js', new Date());
            gtag('config', GA4_ID, {
              send_page_view: false,
              transport_url: SGTM_HOST,
              first_party_collection: true
            });

            // 3. Microsoft Clarity
            (function(c,l,a,r,i,t,y){
                c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
            })(window, document, "clarity", "script", "tjxjn82335");
          }

          // Load scripts on user interaction
          window.addEventListener('scroll', loadTrackingScripts, { passive: true });
          window.addEventListener('mousemove', loadTrackingScripts, { passive: true });
          window.addEventListener('touchstart', loadTrackingScripts, { passive: true });
          window.addEventListener('keydown', loadTrackingScripts, { passive: true });

          // Fallback: load after 4 seconds if no interaction
          setTimeout(loadTrackingScripts, 4000);
        })();
