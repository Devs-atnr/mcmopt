/* General Menu Styles */
.navigation {
  width: 100%;
  position: relative;
}

.menu-container {
  list-style: none;
  padding: 0;
  display: flex;
  gap: 20px;
   padding-left: 15px;
}

.menu-item > a {
    text-decoration: none;
    color: #222;
    font-size: 12px;
    line-height: 16px;
    letter-spacing: 0;
    display: inline-block;
    border-radius: 5px;
}

/* Mega Menu Wrapper */
.mega-menu-wrapper {
  position: absolute;
  top: 100%;
  left: 0;
  width: 100vw;
  background-color: #fff;
    padding: 10px 0 70px 30px;
 
  display: none; /* Initially hidden */
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  z-index: 10;
  height: 62vh;
}

.menu-item:hover > .mega-menu-wrapper {
  display: block; /* Open mega menu on hover */
}
li.menu-item.level-1 {
    padding: 20px 0;
}
/* Submenu Styles */
.submenu {
  list-style: none;
  padding: 0;
  margin: 0;
}

.submenu-item > a {
    text-decoration: none;
    color: #222;
    padding: 5px 10px;
    display: block;
    font-size: 12px;
    line-height: 16px;
    letter-spacing: 0;
    width: 85%;
}

li.submenu-item {
    max-width: 50%;
    display: flex
;
    justify-content: space-between;
    flex-wrap: wrap;
}

/* Level-3 Menu */
.level-3-menu {
    display: none;
    padding: 5px 50px;
    background: #fff;
    margin-top: 0px;
    list-style: none;
    position: relative;
    transition: all 0.3s ease;
    font-size: 12px;
    line-height: 16px;
    letter-spacing: 0;
}

/* Toggle open class for level-3 menus */
.level-3-menu.open {
  display: block;
}

/* Show submenu on hover */
.menu-item:hover .level-3-menu {
  display: block;
}
         
/* Prevent conflicts between hover and toggle */
.menu-item:hover > .mega-menu-wrapper .level-3-menu:not(.open) {
  /* display: none; */
}

/* Add this CSS to rotate the arrow when the menu is open */
.toggle-button .arrow {
  transition: transform 0.3s ease-in-out; /* Smooth transition */
}

.toggle-button[aria-expanded="true"] .arrow {
  transform: rotate(90deg); /* Rotate arrow when menu is open */
}


.level-3-menu {
