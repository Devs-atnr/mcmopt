<script>
document.addEventListener('DOMContentLoaded', function () {
    const menuItems = document.querySelectorAll('.menu-item');

    menuItems.forEach(menuItem => {
        const megaMenuWrapper = menuItem.querySelector('.mega-menu-wrapper');
        let closeTimeout; // Timeout for delayed closure

        // Function to open the mega menu
        const openMegaMenu = () => {
            clearTimeout(closeTimeout); // Clear any pending closure
            megaMenuWrapper.style.display = 'block';
        };

        // Function to close the mega menu with a delay
        const closeMegaMenu = () => {
            closeTimeout = setTimeout(() => {
                // Close the mega menu only if the mouse is not over it or the parent menu item
                if (!menuItem.matches(':hover') && !megaMenuWrapper.matches(':hover')) {
                    megaMenuWrapper.style.display = 'none';
                }
            }, 30); // 5-second delay
        };

        // Open mega menu when hovering over the menu item
        menuItem.addEventListener('mouseenter', openMegaMenu);

        // Close mega menu after delay when leaving the menu item
        menuItem.addEventListener('mouseleave', closeMegaMenu);

        // Keep mega menu open when hovering over it
        megaMenuWrapper.addEventListener('mouseenter', () => {
            clearTimeout(closeTimeout); // Cancel closing if hovering over the mega menu
        });

        // Close mega menu after delay when leaving the mega menu
        megaMenuWrapper.addEventListener('mouseleave', closeMegaMenu);
    });
});

</script>
