; font-family: \"MCM Favorit Bold Extended\"; font-weight: 700; text-align: start; line-height: 48px; text-transform: uppercase; margin-top: 15vh;}","p {font-family: \"MCM Favorit Variable\"; font-size: 14px; line-height: 24px;}",".container-harper {display: flex; flex-direction: column; width: 50vw; margin: auto;}","img.img-1 {padding: 10vh 18vw 10vh;}"],"settings":{"custom_liquid":"<img class=\"img-1\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0888\/3594\/8829\/files\/Harper_5.webp?v=1733818177\"\n>\n\n<div class=\"container-harper\">\n\n\n<p class=\" align-left\"><p class=\" align-left\"> MCM is showcasing its commitment to innovation and new standards of trust and transparency in luxury with the introduction of our first Digital Product Passport (DPP).<br><br>Enabled through the Aura Blockchain Consortium’s platform, customers can simply scan an NFC chip located above the suitcase’s metal plaque to access the DPP. This DPP verifies the product's authenticity and provides detailed information about its sustainability and entire lifecycle,&nbsp;ensuring a comprehensive and transparent customer experience. <\/p> <\/p>\n<\/div>"}},"video_block_RyAQEh":{"type":"video-block","custom_css":[".container {width: 80vw; padding: 0; margin-bottom: 10vh;}"],"settings":{"container":"container","spotlight_bg":"#fff","spotlight_bg_gradient":"","video_block_title":"","color_title":"#232323","fontsize_title":16,"fontsize_title_mb":22,"margin_bottom_title":45,"video_block_des":"","color_des":"#3c3c3c","fontsize_des":16,"title_align":"center","autoplay":true,"video_height":"54","video_height_mb":"100%","style_video":"mp4","video_url":"","video_url_mb":"https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc","url_mp4":"https:\/\/cdn.media.amplience.net\/v\/mcmworldwide\/Comp_HarperCollective_MCMEdit_DPP\/webm_720p?protocol=https","url_mp4_mb":"https:\/\/cdn.media.amplience.net\/v\/mcmworldwide\/Comp_HarperCollective_MCMEdit_DPP\/webm_720p?protocol=https","description":"","full_width":fal